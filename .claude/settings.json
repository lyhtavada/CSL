{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/git-pull.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/git-push.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(claude mcp *)"
    ]
  }
}
